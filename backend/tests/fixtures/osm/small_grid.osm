<?xml version="1.0" encoding="UTF-8"?>
<!--
  small_grid.osm — 3×3 road grid for integration testing.

  Topology:
    n1 ── n2 ── n3
    │     │     │
    n4 ── n5 ── n6
    │     │     │
    n7 ── n8 ── n9

  9 nodes, 12 directed edges (bidirectional road segments).
  All edges are two-way roads with 30 km/h speed limit and ~100 m length.
  Bounding box approx: (39.90, 116.40) – (39.92, 116.42)

  This is a fully connected, strongly connected directed graph,
  suitable for connectivity and station-placement tests.
-->
<osm version="0.6" generator="hand-crafted">
  <!-- Nodes: 3×3 grid ~200 m apart -->
  <node id="1" lat="39.9200" lon="116.4000" version="1"/>
  <node id="2" lat="39.9200" lon="116.4100" version="1"/>
  <node id="3" lat="39.9200" lon="116.4200" version="1"/>
  <node id="4" lat="39.9100" lon="116.4000" version="1"/>
  <node id="5" lat="39.9100" lon="116.4100" version="1"/>
  <node id="6" lat="39.9100" lon="116.4200" version="1"/>
  <node id="7" lat="39.9000" lon="116.4000" version="1"/>
  <node id="8" lat="39.9000" lon="116.4100" version="1"/>
  <node id="9" lat="39.9000" lon="116.4200" version="1"/>

  <!-- Ways: horizontal rows (two-way) -->
  <way id="101" version="1">
    <nd ref="1"/><nd ref="2"/>
    <tag k="highway" v="residential"/>
    <tag k="maxspeed" v="30"/>
    <tag k="oneway" v="no"/>
  </way>
  <way id="102" version="1">
    <nd ref="2"/><nd ref="3"/>
    <tag k="highway" v="residential"/>
    <tag k="maxspeed" v="30"/>
    <tag k="oneway" v="no"/>
  </way>
  <way id="103" version="1">
    <nd ref="4"/><nd ref="5"/>
    <tag k="highway" v="residential"/>
    <tag k="maxspeed" v="30"/>
    <tag k="oneway" v="no"/>
  </way>
  <way id="104" version="1">
    <nd ref="5"/><nd ref="6"/>
    <tag k="highway" v="residential"/>
    <tag k="maxspeed" v="30"/>
    <tag k="oneway" v="no"/>
  </way>
  <way id="105" version="1">
    <nd ref="7"/><nd ref="8"/>
    <tag k="highway" v="residential"/>
    <tag k="maxspeed" v="30"/>
    <tag k="oneway" v="no"/>
  </way>
  <way id="106" version="1">
    <nd ref="8"/><nd ref="9"/>
    <tag k="highway" v="residential"/>
    <tag k="maxspeed" v="30"/>
    <tag k="oneway" v="no"/>
  </way>

  <!-- Ways: vertical columns (two-way) -->
  <way id="201" version="1">
    <nd ref="1"/><nd ref="4"/>
    <tag k="highway" v="residential"/>
    <tag k="maxspeed" v="30"/>
    <tag k="oneway" v="no"/>
  </way>
  <way id="202" version="1">
    <nd ref="4"/><nd ref="7"/>
    <tag k="highway" v="residential"/>
    <tag k="maxspeed" v="30"/>
    <tag k="oneway" v="no"/>
  </way>
  <way id="203" version="1">
    <nd ref="2"/><nd ref="5"/>
    <tag k="highway" v="residential"/>
    <tag k="maxspeed" v="30"/>
    <tag k="oneway" v="no"/>
  </way>
  <way id="204" version="1">
    <nd ref="5"/><nd ref="8"/>
    <tag k="highway" v="residential"/>
    <tag k="maxspeed" v="30"/>
    <tag k="oneway" v="no"/>
  </way>
  <way id="205" version="1">
    <nd ref="3"/><nd ref="6"/>
    <tag k="highway" v="residential"/>
    <tag k="maxspeed" v="30"/>
    <tag k="oneway" v="no"/>
  </way>
  <way id="206" version="1">
    <nd ref="6"/><nd ref="9"/>
    <tag k="highway" v="residential"/>
    <tag k="maxspeed" v="30"/>
    <tag k="oneway" v="no"/>
  </way>
</osm>
